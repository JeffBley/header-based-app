<?xml version="1.0" encoding="utf-8"?>
<!--
  web.config — ASP.NET Core IIS in-process hosting configuration.

  SECURITY: Restrict inbound access to the App Proxy connector host IP using
  IIS IP Address and Domain Restrictions (or Windows Firewall) before deployment.

  The 'forwardWindowsAuthToken' attribute is false (default) because this app
  uses header-based auth supplied by App Proxy, not Windows Auth.
-->
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet"
                  arguments=".\HeaderEchoApp.dll"
                  stdoutLogEnabled="false"
                  stdoutLogFile=".\logs\stdout"
                  hostingModel="inprocess" />
    </system.webServer>
  </location>
</configuration>
